# ── Frontend (Vite) ──────────────────────────────────────────────
# Find these in: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# ── Edge Function Secrets ─────────────────────────────────────────
# Set these with: supabase secrets set KEY=value --project-ref your-project-id
#
# ANTHROPIC_API_KEY  - Required. Get from: console.anthropic.com > API Keys
#                      Used by: analyze-brief, pie-classify, generate-brief, review-content
#
# REVIEWER_EMAIL     - Optional. Your email address for review notifications
#                      Used by: notify-reviewer
#
# RESEND_API_KEY     - Optional. Get from: resend.com > API Keys
#                      Used by: notify-reviewer (only if you want real emails)
